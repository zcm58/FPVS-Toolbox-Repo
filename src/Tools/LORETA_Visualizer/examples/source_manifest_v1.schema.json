{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fpvs-toolbox.local/schemas/loreta/source_manifest_v1.schema.json",
  "title": "FPVS LORETA Visualizer Prepared Source Manifest v1",
  "description": "Shape-only schema for prepared source manifests. The Python validator enforces relative path containment, duplicate ids, and optional payload-file existence checks.",
  "type": "object",
  "additionalProperties": true,
  "required": ["format", "conditions"],
  "properties": {
    "format": {
      "const": "fpvs-loreta-source-manifest-v1"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["label", "file"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^:/\\\\]+(?:[\\\\/][^:/\\\\]+)*\\.json$"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
